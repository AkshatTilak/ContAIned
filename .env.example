# ──────────────────────────────────────────────
# App Settings
# ──────────────────────────────────────────────
APP_NAME=contained-ai-platform
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# Comma-separated list of active project submodules to load
# Remove a project name to disable it (plug-and-play)
ACTIVE_PROJECTS=["syntraflow","guardroute","evalops"]

# OCR extraction source: "local" (loads Baidu model) or "api" (Gemini Flash API via LiteLLM)
OCR_PROVIDER=local
PLATFORM_VERSION=3.0.0
MAX_RAM_MB=16384
VRAM_BUDGET_MB=8000
TIMEOUT_GRACEFUL_SHUTDOWN=15
DEEPEVAL_MODEL=gemini/gemini-3.5-flash
EVALOPS_CONSUMER_ENABLED=false

# Retrieval strategy for SyntraFlow: "vector", "graph", or "hybrid" (Knowledge Graph + Vector Hybrid)
RAG_STRATEGY=hybrid

# ──────────────────────────────────────────────
# Database Settings
# ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://contained:changeme@localhost:5432/contained_platform
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# ──────────────────────────────────────────────
# LLM API Keys
# ──────────────────────────────────────────────
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=

# ──────────────────────────────────────────────
# Inference Server
# ──────────────────────────────────────────────
INFERENCE_SERVER_URL=http://localhost:8010
INFERENCE_SERVER_PORT=8010

# ──────────────────────────────────────────────
# Observability & Tracing
# ──────────────────────────────────────────────
OTEL_SERVICE_NAME=contained-platform
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=contained-platform
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ──────────────────────────────────────────────
# Model Paths (Inference Server)
# ──────────────────────────────────────────────
CLASSIFIER_MODEL_PATH=models/Arch-Router-1.5B-Q8_0.gguf
CLASSIFIER_IDLE_TIMEOUT=300

# ──────────────────────────────────────────────
# MLflow (SyntraFlow fine-tuning tracking)
# ──────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
